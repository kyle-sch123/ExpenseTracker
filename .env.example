# ── App ──────────────────────────────────────────────────────────────────────
APP_URL=https://your-app.onrender.com
PORT=3000

# ── Google Gemini (free tier: 250 requests/day) ──────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Database connection (Supabase). For best connection behaviour use the
# Supabase connection pooler (port 6543); the direct connection (port 5432)
# also works fine at small scale.
DATABASE_URL=postgresql://postgres:password@host:6543/postgres?pgbouncer=true

# ── Meta WhatsApp Cloud API ──────────────────────────────────────────────────
WHATSAPP_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_ID=your-phone-number-id
VERIFY_TOKEN=any-custom-string-for-webhook-verification
# App secret (Meta App → Settings → Basic) — used to verify webhook signatures.
META_APP_SECRET=your-meta-app-secret

# ── Access control ───────────────────────────────────────────────────────────
# The admin's WhatsApp number (international format). Seeded as an active admin
# on startup; only this number can approve/invite/block other users.
ADMIN_PHONE=27821234567

# Max receipt photos a single user may process per day (protects shared quota).
MAX_RECEIPTS_PER_DAY=30
